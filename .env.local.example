# Copy this to .env.local and fill in real values
# The real .env.local is committed to the repo for full transparency

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin panel
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
ADMIN_SECRET_SALT=your_salt
OWNER_PASSWORD=your_owner_password

# Vercel deploy hook
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy

# Toast ordering
TOAST_ORDER_URL=https://order.toasttab.com/online/your-location

# Email (Resend)
EMAIL_API_KEY=your_resend_api_key

# Analytics
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXX
NEXT_PUBLIC_GSC_VERIFICATION=your_gsc_verification_code
