# Vercel deploy hook (Settings → Git → Deploy Hooks in your Vercel project)
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy

# Email service (Resend)
EMAIL_API_KEY=your_resend_api_key_here

NEXT_PUBLIC_SUPABASE_URL=https://usojwldqvxnzqgfxtkqn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin panel credentials (never use NEXT_PUBLIC_ prefix)
ADMIN_USERNAME=Ameet
ADMIN_PASSWORD=your_admin_password_here
ADMIN_SECRET_SALT=your_salt_here
# Owner override — silent full access, never shown in UI
OWNER_PASSWORD=your_owner_password_here

# Toast ordering URL
TOAST_ORDER_URL=https://order.toasttab.com/online/elephant-wings-parlor

# Analytics (optional)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXX
NEXT_PUBLIC_GSC_VERIFICATION=your_gsc_verification_code
